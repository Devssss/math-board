rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'totalXp', 'totalKid', 'level', 'streak']) &&
             data.keys().size() == 5 &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.totalXp is number && data.totalKid is number &&
             data.level is number && data.streak is number;
    }

    match /users/{userId} {
      allow read: if isSignedIn(); // Allow reading other profiles for leaderboard
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Only allow XP, KID, level, and streak to increase/change correctly
        incoming().diff(existing()).affectedKeys().hasOnly(['totalXp', 'totalKid', 'level', 'streak', 'displayName'])
      );
    }

    // Completed Quests Validation
    function isValidCompletedQuest(data) {
      return data.keys().hasAll(['questId', 'completedAt', 'reward']) &&
             data.keys().size() == 3 &&
             data.questId is number &&
             data.completedAt == request.time && // Use server timestamp
             data.reward is number;
    }

    match /users/{userId}/completedQuests/{questId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidCompletedQuest(incoming());
      // No updates or deletes allowed for completed records to prevent exploitation
    }
  }
}
